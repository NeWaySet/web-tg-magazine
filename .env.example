DATABASE_HOST=localhost
DATABASE_NAME=nuzdin_db
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_PORT=5432

SECRET_KEY=replace-with-long-secret
TELEGRAM_BOT_TOKEN=replace-with-botfather-token
FLASK_DEBUG=False

# Field-level encryption for emails, delivery addresses and order snapshots.
# Generate DATA_ENCRYPTION_KEY after installing requirements:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# DATA_HASH_KEY must stay stable too; generate with: openssl rand -hex 32
DATA_ENCRYPTION_KEY=replace-with-fernet-key
DATA_HASH_KEY=replace-with-random-hmac-key

# Crypto QR. By default the QR contains payment instructions with this address.
CRYPTO_ASSET=USDT
CRYPTO_NETWORK=TRC20
CRYPTO_ADDRESS=replace-with-wallet-address
CRYPTO_USDT_RUB_RATE=
CRYPTO_RATE_URL=https://www.cbr.ru/scripts/XML_daily.asp
CRYPTO_RATE_CACHE_SECONDS=3600

# Optional: override crypto QR payload. Available placeholders:
# {amount}, {amount_kop}, {payment_id}, {order_id}, {comment},
# {crypto_address}, {crypto_asset}, {crypto_network}, {crypto_amount}, {crypto_rate}, {method}
CRYPTO_QR_PAYLOAD_TEMPLATE=

# SBP QR requires a bank/payment-provider merchant payload.
# Put the provider payload template here. The same placeholders are available.
SBP_QR_PAYLOAD_TEMPLATE=

# Admin panel network guard.
# ADMIN_ALLOWED_IPS limits client IPs, comma-separated.
# ADMIN_ALLOWED_HOSTS limits the host/IP used to open admin panel, comma-separated.
ADMIN_ALLOWED_IPS=
ADMIN_ALLOWED_HOSTS=78.17.67.131
